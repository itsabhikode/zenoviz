# Vite / `ng serve` only exposes variables prefixed with VITE_ to the app.
# If you used API_BASE_URL or COGNITO_* without VITE_, rename them (e.g. API_BASE_URL → VITE_API_BASE_URL).
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: Sign in with Google via Cognito Hosted UI (PKCE). Copy to `.env` and fill in.
# VITE_COGNITO_HOSTED_UI_DOMAIN=my-app.auth.us-east-1.amazoncognito.com
# VITE_COGNITO_APP_CLIENT_ID=same_as_backend_pool_app_client
# VITE_OAUTH_REDIRECT_URI=http://localhost:4200/auth/callback
# VITE_COGNITO_GOOGLE_IDENTITY_PROVIDER=Google
