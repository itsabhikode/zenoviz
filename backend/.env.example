COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1
COGNITO_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX/.well-known/jwks.json

# Study room booking (SQLAlchemy async)
DATABASE_URL=sqlite+aiosqlite:///./zenoviz.db
PAYMENT_UPLOAD_DIR=./data/payment_proofs
BOOKING_EXPIRY_INTERVAL_SECONDS=60

# RBAC bootstrap: comma-separated emails or Cognito subs that
# auto-receive the `admin` role on their first authenticated request.
# Set to the email(s) of your initial admin(s). Supports multiple, e.g.:
#   BOOTSTRAP_ADMINS=alice@corp.com,bob@corp.com
# Leave empty in prod once your first admin exists and promotes others via /admin/roles/grant.
BOOTSTRAP_ADMINS=you@example.com
