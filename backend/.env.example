COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1
COGNITO_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX/.well-known/jwks.json

# If Cognito verifies by SMS: codes are sent by AWS SNS (not this app). In the AWS console,
# raise the SNS SMS monthly spend limit, ensure the Cognito SMS IAM role can Publish to SNS,
# and check regional SMS rules (some countries block or require sender registration).

# IAM credentials for boto3 (required for Cognito APIs from this server, including admin ListUsers).
# Loaded via Cognito settings — boto3 does not read `.env` by itself.
# Omit if you rely on ~/.aws/credentials, `aws configure`, AWS SSO env vars, or an IAM role.
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_SESSION_TOKEN=

# Study room booking (SQLAlchemy async)
DATABASE_URL=sqlite+aiosqlite:///./zenoviz.db
PAYMENT_UPLOAD_DIR=./data/payment_proofs
BOOKING_EXPIRY_INTERVAL_SECONDS=60

# Admin access: Cognito group name that maps to API role `admin` (must match your pool group).
COGNITO_ADMIN_GROUP=Admin

# Image uploads: set S3 bucket to store payment proofs + payment QR (omit for local filesystem).
# General-purpose buckets: use the normal bucket name.
# S3 Express "directory" buckets (names like *--use1-az4--x-s3): use COGNITO_REGION matching the bucket;
# the API automatically uses the correct zonal s3express-… endpoint for PutObject/GetObject.
# Optional override if AWS changes endpoint layout:
# S3_ZONAL_ENDPOINT=https://s3express-use1-az4.us-east-1.amazonaws.com
# S3_UPLOADS_BUCKET=zenoviz--use1-az4--x-s3
# S3_UPLOADS_PREFIX=zenoviz

# Optional: public HTTPS URL prefix for QR images (same path as ``{S3_UPLOADS_PREFIX}/payment-qr/``
# after the bucket hostname). Enables clients to load the QR via <img src> instead of API bytes.
# Example virtual-hosted-style: https://YOUR_BUCKET.s3.YOUR_REGION.amazonaws.com/YOUR_PREFIX
# PAYMENT_QR_PUBLIC_BASE_URL=https://example-bucket.s3.us-east-1.amazonaws.com/zenoviz

# IAM identity needs s3:PutObject/GetObject on that bucket prefix and cognito-idp group APIs for admin.
